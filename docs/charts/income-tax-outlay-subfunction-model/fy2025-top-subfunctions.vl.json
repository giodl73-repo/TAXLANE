{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "FY2025 Modeled Individual Income-Tax Allocation by Top Subfunction",
  "data": {
    "url": "../../../data/derived/income_tax_outlay_subfunction_model/income_tax_outlay_subfunction_model.omb-fy2027.2026-06-21.fy2025-top-subfunctions.csv",
    "format": {
      "type": "csv"
    }
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "subfunction_label",
      "type": "nominal",
      "title": "Subfunction",
      "sort": "-x"
    },
    "x": {
      "field": "modeled_income_tax_allocation_millions",
      "type": "quantitative",
      "title": "Modeled allocation, millions of dollars",
      "axis": {
        "format": ",.0f"
      }
    },
    "color": {
      "field": "function_label",
      "type": "nominal",
      "title": "Function",
      "scale": {
        "range": [
          "#4E79A7",
          "#F28E2B",
          "#59A14F",
          "#E15759",
          "#76B7B2",
          "#B07AA1",
          "#9C755F",
          "#BAB0AC"
        ]
      }
    },
    "tooltip": [
      {
        "field": "rank",
        "type": "ordinal",
        "title": "Rank"
      },
      {
        "field": "function_label",
        "type": "nominal",
        "title": "Function"
      },
      {
        "field": "subfunction_label",
        "type": "nominal",
        "title": "Subfunction"
      },
      {
        "field": "modeled_income_tax_allocation_millions",
        "type": "quantitative",
        "title": "Modeled allocation",
        "format": ",.0f"
      },
      {
        "field": "allocation_share_percent",
        "type": "quantitative",
        "title": "Modeled share",
        "format": ".1f"
      },
      {
        "field": "legal_allocation_status",
        "type": "nominal",
        "title": "Legal status"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}
