{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Modeled Individual Income-Tax Allocation Trends for Selected Subfunctions",
  "data": {
    "url": "../../../data/derived/income_tax_outlay_subfunction_model/income_tax_outlay_subfunction_model.omb-fy2027.2026-06-21.annual-long.csv",
    "format": {
      "type": "csv"
    }
  },
  "transform": [
    {
      "filter": "indexof(['Social security', 'Interest on Treasury debt securities (gross)', 'Medicare', 'Health care services', 'Department of Defense-Military'], datum.subfunction_label) >= 0"
    }
  ],
  "mark": {
    "type": "line",
    "point": false
  },
  "encoding": {
    "x": {
      "field": "fiscal_year",
      "type": "ordinal",
      "title": "Fiscal year",
      "axis": {
        "labelAngle": 0,
        "labelExpr": "datum.value % 10 == 0 ? datum.value : ''"
      }
    },
    "y": {
      "field": "allocation_share_percent",
      "type": "quantitative",
      "title": "Modeled share of individual income-tax receipts",
      "axis": {
        "format": ".0f"
      }
    },
    "color": {
      "field": "subfunction_label",
      "type": "nominal",
      "title": "Subfunction",
      "scale": {
        "domain": [
          "Social security",
          "Interest on Treasury debt securities (gross)",
          "Medicare",
          "Health care services",
          "Department of Defense-Military"
        ],
        "range": [
          "#4E79A7",
          "#F28E2B",
          "#59A14F",
          "#E15759",
          "#76B7B2"
        ]
      }
    },
    "tooltip": [
      {
        "field": "fiscal_year",
        "type": "ordinal",
        "title": "Fiscal year"
      },
      {
        "field": "function_label",
        "type": "nominal",
        "title": "Function"
      },
      {
        "field": "subfunction_label",
        "type": "nominal",
        "title": "Subfunction"
      },
      {
        "field": "allocation_share_percent",
        "type": "quantitative",
        "title": "Modeled share",
        "format": ".1f"
      },
      {
        "field": "modeled_income_tax_allocation_millions",
        "type": "quantitative",
        "title": "Modeled allocation",
        "format": ",.0f"
      },
      {
        "field": "legal_allocation_status",
        "type": "nominal",
        "title": "Legal status"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}
