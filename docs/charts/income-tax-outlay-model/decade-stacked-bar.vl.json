{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Modeled Allocation of Individual Income-Tax Receipts by Decade",
  "data": {
    "url": "../../../data/derived/income_tax_outlay_model/income_tax_outlay_model.omb-fy2027.2026-06-21.decade-wide.csv",
    "format": {
      "type": "csv"
    }
  },
  "transform": [
    {
      "fold": [
        "national_defense_percent",
        "human_resources_percent",
        "physical_resources_percent",
        "net_interest_percent",
        "other_functions_percent",
        "offsetting_receipts_percent"
      ],
      "as": [
        "category",
        "percent"
      ]
    },
    {
      "calculate": "datum.category == 'national_defense_percent' ? 'National defense' : datum.category == 'human_resources_percent' ? 'Human resources' : datum.category == 'physical_resources_percent' ? 'Physical resources' : datum.category == 'net_interest_percent' ? 'Net interest' : datum.category == 'other_functions_percent' ? 'Other functions' : 'Offsetting receipts'",
      "as": "category_label"
    }
  ],
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "decade",
      "type": "ordinal",
      "title": "Decade"
    },
    "y": {
      "field": "percent",
      "type": "quantitative",
      "title": "Modeled share of decade income-tax receipts",
      "axis": {
        "format": ".0f"
      },
      "stack": "zero"
    },
    "color": {
      "field": "category_label",
      "type": "nominal",
      "title": "Modeled category",
      "scale": {
        "domain": [
          "National defense",
          "Human resources",
          "Physical resources",
          "Net interest",
          "Other functions",
          "Offsetting receipts"
        ],
        "range": [
          "#4E79A7",
          "#59A14F",
          "#F28E2B",
          "#9C755F",
          "#B07AA1",
          "#BAB0AC"
        ]
      }
    },
    "tooltip": [
      {
        "field": "decade",
        "type": "ordinal",
        "title": "Decade"
      },
      {
        "field": "coverage_note",
        "type": "nominal",
        "title": "Coverage"
      },
      {
        "field": "category_label",
        "type": "nominal",
        "title": "Category"
      },
      {
        "field": "percent",
        "type": "quantitative",
        "title": "Modeled share",
        "format": ".1f"
      },
      {
        "field": "borrowed_share_percent_of_outlays",
        "type": "quantitative",
        "title": "Borrowed share of outlays",
        "format": ".1f"
      },
      {
        "field": "income_tax_coverage_percent_of_outlays",
        "type": "quantitative",
        "title": "Income-tax coverage of outlays",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}
